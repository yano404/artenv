#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "${script_dir}/util.sh"

print_ok() {
  printf '  [OK] %s\n' "$1"
}

print_ng() {
  printf '  [NG] %s\n' "$1"
}

check_dir() {
  local label="$1"
  local path="$2"

  if [[ -d "${path}" ]]; then
    print_ok "${label}: ${path}"
    return 0
  else
    print_ng "${label}: ${path}"
    return 1
  fi
}

check_file() {
  local label="$1"
  local path="$2"

  if [[ -f "${path}" ]]; then
    print_ok "${label}: ${path}"
    return 0
  else
    print_ng "${label}: ${path}"
    return 1
  fi
}

doctor_env() {
  local env_name="$1"
  local env_conf="${ARTENV_ROOT}/envs/${env_name}.toml"
  local ok=0

  printf 'env: %s\n' "${env_name}"

  check_file "env config" "${env_conf}" || { ok=1; printf 'result: NG\n\n'; return 1; }

  local version_name work_dir git_repos use_artlogin_raw
  version_name="$(toml_get "${env_conf}" 'env' 'version')"
  work_dir="$(toml_get "${env_conf}" 'env' 'work')"
  git_repos="$(toml_get "${env_conf}" 'env' 'git_repos' '')"
  use_artlogin_raw="$(toml_get "${env_conf}" 'env' 'use_artlogin' 'false')"

  if [[ -n "${version_name}" ]]; then
    print_ok "env.version: ${version_name}"
  else
    print_ng "env.version: not set"
    ok=1
  fi

  local version_conf="${ARTENV_ROOT}/versions/${version_name}.toml"
  if check_file "version config" "${version_conf}"; then
    local version_type
    version_type="$(toml_get "${version_conf}" 'version' 'type' 'native')"

    if [[ "${version_type}" == "apptainer" ]]; then
      local image
      image="$(toml_get "${version_conf}" 'version' 'image')"
      check_file "image" "${image}" || ok=1

      if command -v apptainer >/dev/null 2>&1; then
        print_ok "apptainer: $(command -v apptainer)"
      else
        print_ng "apptainer: command not found"
        ok=1
      fi

      local binds
      binds="$(yq -p toml -oy -r '.env.binds // [] | join(",")' "${env_conf}")"
      if [[ -n "${binds}" ]]; then
        local IFS=','
        local bind_path
        for bind_path in ${binds}; do
          check_dir "bind" "${bind_path}" || ok=1
        done
      else
        print_ok "binds: not set"
      fi
    else
      local artsys rootsys yamllib yamlcmake
      artsys="$(toml_get "${version_conf}" 'version' 'artsys')"
      rootsys="$(toml_get "${version_conf}" 'version' 'rootsys')"
      yamllib="$(toml_get "${version_conf}" 'version' 'yamllib')"
      yamlcmake="$(toml_get "${version_conf}" 'version' 'yamlcmake')"

      check_dir "artsys" "${artsys}"    || ok=1
      check_dir "rootsys" "${rootsys}"  || ok=1
      check_dir "yamllib" "${yamllib}"  || ok=1
      check_dir "yamlcmake" "${yamlcmake}" || ok=1
      check_file "root-config" "${rootsys}/bin/root-config" || ok=1
    fi
  else
    ok=1
  fi

  check_dir "work dir" "${work_dir}" || ok=1

  if [[ -n "${git_repos}" ]]; then
    print_ok "git_repos: ${git_repos}"
  else
    print_ok "git_repos: not set"
  fi

  if [[ "${use_artlogin_raw}" == "true" ]]; then
    local artlogin_sh="${ARTENV_ROOT}/envs/${env_name}.artlogin.sh"
    check_file "artlogin.sh" "${artlogin_sh}" || ok=1
  else
    print_ok "artlogin.sh: not set"
  fi

  if [[ ${ok} -eq 0 ]]; then
    printf 'result: OK\n'
  else
    printf 'result: NG\n'
  fi

  printf '\n'
  return "${ok}"
}

doctor_current() {
  [[ -n "${ART_PROJECT:-}" ]] || die "ART_PROJECT is not set"
  doctor_env "${ART_PROJECT}"
}

doctor_all() {
  local envs_dir="${ARTENV_ROOT}/envs"
  local failed=0

  require_dir "${envs_dir}"

  local -a confs=()
  shopt -s nullglob
  confs=("${envs_dir}"/*.toml)
  shopt -u nullglob

  if [[ ${#confs[@]} -eq 0 ]]; then
    die "no environments are registered"
  fi

  local conf env_name
  for conf in "${confs[@]}"; do
    env_name="$(basename "${conf}" .toml)"
    if ! doctor_env "${env_name}"; then
      failed=1
    fi
  done

  return "${failed}"
}

main() {
  [[ -n "${ARTENV_ROOT:-}" ]] || die "ARTENV_ROOT is not set"
  require_yq
  [[ $# -le 1 ]] || die "usage: artenv doctor [env|--all]"

  if [[ $# -eq 0 ]]; then
    doctor_current
    exit $?
  fi

  case "$1" in
    --all)
      doctor_all
      ;;
    *)
      doctor_env "$1"
      ;;
  esac
}

main "$@"
